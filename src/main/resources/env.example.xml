<?xml version="1.0" encoding="UTF-8"?>
<!-- 
    HƯỚNG DẪN: 
    1. Copy file này và đổi tên thành 'env.xml' (đặt cùng thư mục).
    2. Cập nhật các thông số <url>, <user>, <password> bên dưới phù hợp với môi trường cục bộ.
    3. File 'env.xml' đã được ignore trong git để bảo mật.
-->
<env>
    <db>
        <url>jdbc:sqlserver://localhost:1433;databaseName=YOUR_DB_NAME;encrypt=true;trustServerCertificate=true</url>
        <user>YOUR_USER</user>
        <password>YOUR_PASSWORD</password>
    </db>
</env>
